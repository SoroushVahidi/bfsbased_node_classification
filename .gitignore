*.py[cod]
*$py.class
.Python
*.so
.venv/
.venv_begga/
venv/
.env

# OGB raw downloads (large; reproducible via `ogb` / prepare script)
data/ogb/

# PyG / torch-geometric disk cache (regenerates on load)
data/pyg_cache/

# Redundant local bundles (source of truth is logs/code dirs)
diagnosis_bundle*.tar.gz
_push_*.tar.gz
_push_*.tar.gz.part.*

# Point-in-time diagnosis snapshots (prefer logs/; large JSON — keep local only if needed)
code/bfsbased_node_classification/diagnosis/

# Editor
.idea/
.vscode/
*.swp

# Slurm stdout/stderr (cluster-local; regenerate by re-running jobs)
slurm/*.out
slurm/*.err

# Large / reproducible benchmark outputs (regenerate via suite scripts and Slurm)
outputs/baseline_comparison/
